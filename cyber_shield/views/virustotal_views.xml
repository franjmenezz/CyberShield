<odoo>
    <data>

        <!-- VT ANALYSIS LIST -->
        <record id="view_cyber_vt_list" model="ir.ui.view">
            <field name="name">cyber.vt.analysis.list</field>
            <field name="model">cyber.vt.analysis</field>
            <field name="arch" type="xml">
                <list string="VirusTotal Analyses" create="false"
                      decoration-danger="state == 'malicious'"
                      decoration-warning="state == 'suspicious'"
                      decoration-success="state == 'clean'"
                      decoration-muted="state in ['not_found', 'error']">
                    <field name="analysed_at" string="Analysed"/>
                    <field name="indicator_type" string="Type"/>
                    <field name="indicator_value" string="Indicator"/>
                    <field name="state" string="Verdict"
                           decoration-danger="state == 'malicious'"
                           decoration-warning="state == 'suspicious'"
                           decoration-success="state == 'clean'"/>
                    <field name="detection_rate" string="Detections"/>
                    <field name="threat_label" string="Threat"/>
                    <field name="device_id" string="Device"/>
                    <field name="alert_id" string="Alert Generated"/>
                    <field name="vt_link" invisible="1"/>
                    <button name="action_reanalyse" type="object" string="🔄 Re-analyse"/>
                </list>
            </field>
        </record>

        <!-- VT ANALYSIS FORM -->
        <record id="view_cyber_vt_form" model="ir.ui.view">
            <field name="name">cyber.vt.analysis.form</field>
            <field name="model">cyber.vt.analysis</field>
            <field name="arch" type="xml">
                <form string="VirusTotal Analysis" create="false">
                    <header>
                        <button name="action_open_vt_report" type="object"
                                string="🔗 Open Full VT Report"
                                class="btn-primary"
                                invisible="not vt_link"/>
                        <button name="action_reanalyse" type="object"
                                string="🔄 Re-analyse"
                                class="btn-secondary"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="pending,clean,suspicious,malicious"/>
                    </header>
                    <sheet>
                        <div class="alert alert-danger" invisible="state != 'malicious'">
                            <strong>🔴 MALICIOUS INDICATOR DETECTED</strong>
                        </div>
                        <div class="alert alert-warning" invisible="state != 'suspicious'">
                            <strong>⚠️ SUSPICIOUS INDICATOR</strong>
                        </div>
                        <div class="alert alert-success" invisible="state != 'clean'">
                            <strong>✅ CLEAN</strong> — No malicious detections found.
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="indicator_type" readonly="1"/>:
                                <field name="indicator_value" readonly="1"/>
                            </h1>
                        </div>
                        <group string="Analysis Results">
                            <group>
                                <field name="indicator_type" readonly="1"/>
                                <field name="indicator_value" readonly="1"/>
                                <field name="state" readonly="1"/>
                                <field name="threat_label" readonly="1"/>
                            </group>
                            <group>
                                <field name="malicious_count" readonly="1"/>
                                <field name="suspicious_count" readonly="1"/>
                                <field name="harmless_count" readonly="1"/>
                                <field name="total_engines" readonly="1"/>
                                <field name="detection_rate" readonly="1"/>
                            </group>
                        </group>
                        <group string="References">
                            <field name="analysed_at" readonly="1"/>
                            <field name="device_id" readonly="1"/>
                            <field name="log_id" readonly="1"/>
                            <field name="alert_id" readonly="1"/>
                            <field name="vt_link" readonly="1" widget="url"/>
                        </group>
                        <group string="Raw API Response (Admin only)"
                               groups="cyber_shield.group_cyber_admin">
                            <field name="raw_response" readonly="1" nolabel="1" widget="text"/>
                        </group>
                        <group string="Error Details" invisible="state != 'error'">
                            <field name="error_message" readonly="1" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- VT SEARCH -->
        <record id="view_cyber_vt_search" model="ir.ui.view">
            <field name="name">cyber.vt.analysis.search</field>
            <field name="model">cyber.vt.analysis</field>
            <field name="arch" type="xml">
                <search string="Search VT Analyses">
                    <field name="indicator_value" string="Indicator"/>
                    <field name="device_id"/>
                    <separator/>
                    <filter string="Malicious" name="malicious" domain="[('state', '=', 'malicious')]"/>
                    <filter string="Suspicious" name="suspicious" domain="[('state', '=', 'suspicious')]"/>
                    <filter string="Clean" name="clean" domain="[('state', '=', 'clean')]"/>
                    <filter string="Hashes" name="hashes" domain="[('indicator_type', '=', 'hash')]"/>
                    <filter string="IPs" name="ips" domain="[('indicator_type', '=', 'ip')]"/>
                    <filter string="URLs" name="urls" domain="[('indicator_type', '=', 'url')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Verdict" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Type" name="group_type" context="{'group_by': 'indicator_type'}"/>
                        <filter string="Device" name="group_device" context="{'group_by': 'device_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- VT ACTIONS -->
        <record id="action_cyber_vt_analyses" model="ir.actions.act_window">
            <field name="name">VirusTotal Analyses</field>
            <field name="res_model">cyber.vt.analysis</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_cyber_vt_search"/>
        </record>

        <record id="action_cyber_vt_malicious" model="ir.actions.act_window">
            <field name="name">Malicious Indicators</field>
            <field name="res_model">cyber.vt.analysis</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', 'in', ['malicious', 'suspicious'])]</field>
        </record>

    </data>
</odoo>
