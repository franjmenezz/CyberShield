<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════════════════
             CYBER.LOG — VIEWS
        ══════════════════════════════════════════════════════════════════════ -->
        <record id="view_cyber_log_list" model="ir.ui.view">
            <field name="name">cyber.log.list</field>
            <field name="model">cyber.log</field>
            <field name="arch" type="xml">
                <list string="Activity Logs" create="false" edit="false" delete="false"
                      decoration-danger="severity == 'critical'"
                      decoration-warning="severity == 'high'"
                      default_order="timestamp desc">
                    <field name="timestamp" string="Timestamp"/>
                    <field name="device_id" string="Device"/>
                    <field name="event_type" string="Event"/>
                    <field name="severity" string="Severity"
                           decoration-danger="severity == 'critical'"
                           decoration-warning="severity == 'high'"
                           decoration-info="severity == 'medium'"/>
                    <field name="description" string="Description"/>
                    <field name="user_name" string="User"/>
                    <field name="source_ip" string="Source IP"/>
                    <field name="mitre_tactic" string="MITRE Tactic" optional="show"/>
                    <field name="mitre_technique" string="MITRE Tech." optional="show"/>
                    <field name="wazuh_rule_id" string="Rule ID" optional="hide"/>
                    <field name="alert_id" string="Alert" optional="show"/>
                </list>
            </field>
        </record>

        <record id="view_cyber_log_form" model="ir.ui.view">
            <field name="name">cyber.log.form</field>
            <field name="model">cyber.log</field>
            <field name="arch" type="xml">
                <form string="Activity Log" create="false" edit="false" delete="false">
                    <sheet>
                        <div class="alert alert-info">
                            <strong>🔒 IMMUTABLE RECORD</strong> — This log entry cannot be modified or deleted.
                            Integrity verified via HMAC-SHA256 hash chaining.
                        </div>
                        <group string="Event Identity">
                            <group>
                                <field name="log_uid" readonly="1"/>
                                <field name="timestamp" readonly="1"/>
                                <field name="device_id" readonly="1"/>
                                <field name="event_type" readonly="1"/>
                                <field name="severity" readonly="1"/>
                            </group>
                            <group>
                                <field name="source_ip" readonly="1"/>
                                <field name="user_name" readonly="1"/>
                                <field name="process_name" readonly="1"/>
                                <field name="file_path" readonly="1"/>
                                <field name="wazuh_agent_id" readonly="1"/>
                            </group>
                        </group>
                        <group string="MITRE ATT&amp;CK">
                            <field name="mitre_tactic" readonly="1"/>
                            <field name="mitre_technique" readonly="1"/>
                        </group>
                        <group string="Network">
                            <group>
                                <field name="destination_ip" readonly="1"/>
                                <field name="destination_port" readonly="1"/>
                            </group>
                            <group>
                                <field name="wazuh_rule_id" readonly="1"/>
                                <field name="wazuh_rule_level" readonly="1"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" readonly="1" nolabel="1"/>
                        </group>
                        <group string="Integrity Chain"
                               groups="cyber_shield.group_cyber_admin">
                            <field name="event_hash" readonly="1"/>
                            <field name="previous_hash" readonly="1"/>
                        </group>
                        <group string="Alert Generated">
                            <field name="alert_id" readonly="1"/>
                        </group>
                        <group string="Raw Data" groups="cyber_shield.group_cyber_admin">
                            <field name="raw_data" readonly="1" nolabel="1" widget="text"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_verify_integrity" type="object"
                                string="Verify Integrity" class="btn-primary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_cyber_log_search" model="ir.ui.view">
            <field name="name">cyber.log.search</field>
            <field name="model">cyber.log</field>
            <field name="arch" type="xml">
                <search string="Search Logs">
                    <field name="device_id"/>
                    <field name="description"/>
                    <field name="user_name"/>
                    <field name="source_ip"/>
                    <separator/>
                    <filter string="Critical" name="critical" domain="[('severity','=','critical')]"/>
                    <filter string="High" name="high" domain="[('severity','=','high')]"/>
                    <filter string="Today" name="today" domain="[('timestamp','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Device" name="group_device" context="{'group_by': 'device_id'}"/>
                        <filter string="Event Type" name="group_event" context="{'group_by': 'event_type'}"/>
                        <filter string="Severity" name="group_severity" context="{'group_by': 'severity'}"/>
                        <filter string="MITRE Tactic" name="group_mitre" context="{'group_by': 'mitre_tactic'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_cyber_logs" model="ir.actions.act_window">
            <field name="name">Activity Logs</field>
            <field name="res_model">cyber.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_cyber_log_search"/>
        </record>

        <record id="action_cyber_logs_critical" model="ir.actions.act_window">
            <field name="name">Critical Events</field>
            <field name="res_model">cyber.log</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('severity', 'in', ['critical', 'high'])]</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             CYBER.ALERT — VIEWS
        ══════════════════════════════════════════════════════════════════════ -->
        <record id="view_cyber_alert_list" model="ir.ui.view">
            <field name="name">cyber.alert.list</field>
            <field name="model">cyber.alert</field>
            <field name="arch" type="xml">
                <list string="Alerts"
                      decoration-danger="severity == 'critical' or sla_breached == True"
                      decoration-warning="severity == 'high'"
                      decoration-muted="state in ['resolved', 'false_positive']">
                    <field name="reference" string="Ref"/>
                    <field name="name" string="Alert"/>
                    <field name="device_id" string="Device"/>
                    <field name="severity" string="Severity"
                           decoration-danger="severity == 'critical'"
                           decoration-warning="severity == 'high'"/>
                    <field name="alert_type" string="Type"/>
                    <field name="state" string="State"
                           decoration-success="state == 'resolved'"
                           decoration-muted="state == 'false_positive'"/>
                    <field name="mitre_tactic" string="Tactic" optional="show"/>
                    <field name="assigned_to_id" string="Assigned To"/>
                    <field name="sla_deadline" string="SLA Deadline"
                           decoration-danger="sla_breached == True"/>
                    <field name="sla_breached" string="SLA" widget="boolean"/>
                    <field name="create_date" string="Created"/>
                </list>
            </field>
        </record>

        <record id="view_cyber_alert_form" model="ir.ui.view">
            <field name="name">cyber.alert.form</field>
            <field name="model">cyber.alert</field>
            <field name="arch" type="xml">
                <form string="Security Alert">
                    <header>
                        <button name="action_acknowledge" type="object"
                                string="Acknowledge" class="btn-secondary"
                                attrs="{'invisible': [('state', '!=', 'new')]}"/>
                        <button name="action_investigate" type="object"
                                string="Investigate" class="btn-primary"
                                attrs="{'invisible': [('state', 'not in', ['new', 'acknowledged'])]}"/>
                        <button name="action_contain" type="object"
                                string="Contain" class="btn-warning"
                                attrs="{'invisible': [('state', '!=', 'investigating')]}"/>
                        <button name="action_resolve" type="object"
                                string="Resolve" class="btn-success"
                                attrs="{'invisible': [('state', 'not in', ['acknowledged', 'investigating', 'contained'])]}"/>
                        <button name="action_false_positive" type="object"
                                string="False Positive" class="btn-secondary"
                                attrs="{'invisible': [('state', 'in', ['resolved', 'false_positive'])]}"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="new,acknowledged,investigating,contained,resolved"/>
                    </header>
                    <sheet>
                        <!-- SLA breach banner -->
                        <div class="alert alert-danger" role="alert"
                             attrs="{'invisible': [('sla_breached', '=', False)]}">
                            <strong>⚠️ SLA BREACHED</strong> — This alert has exceeded its response deadline.
                        </div>

                        <div class="oe_title">
                            <span class="o_field_widget o_field_badge" name="severity"/>
                            <h1><field name="name"/></h1>
                            <h3 style="color:#64748b;"><field name="reference" readonly="1"/></h3>
                        </div>

                        <group>
                            <group string="Classification">
                                <field name="severity"/>
                                <field name="alert_type"/>
                                <field name="device_id"/>
                                <field name="source_ip"/>
                            </group>
                            <group string="MITRE ATT&amp;CK">
                                <field name="mitre_tactic"/>
                                <field name="mitre_technique"/>
                                <field name="destination_ip"/>
                                <field name="destination_port"/>
                            </group>
                        </group>

                        <group string="SLA &amp; Assignment">
                            <group>
                                <field name="assigned_to_id"/>
                                <field name="sla_deadline" readonly="1"/>
                                <field name="sla_breached" readonly="1"/>
                            </group>
                            <group>
                                <field name="acknowledged_by_id" readonly="1"/>
                                <field name="acknowledged_date" readonly="1"/>
                                <field name="resolved_by_id" readonly="1"/>
                                <field name="resolved_date" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Description &amp; Remediation">
                                <group string="Description">
                                    <field name="description" nolabel="1"/>
                                </group>
                                <group string="Recommended Remediation">
                                    <field name="remediation" nolabel="1"/>
                                </group>
                                <group string="Resolution Notes"
                                       attrs="{'invisible': [('state', 'not in', ['resolved', 'false_positive'])]}">
                                    <field name="resolution_notes" nolabel="1"/>
                                </group>
                            </page>
                            <page string="Source Log">
                                <field name="log_id" readonly="1"/>
                            </page>
                            <page string="Incident">
                                <field name="incident_id"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_cyber_alert_search" model="ir.ui.view">
            <field name="name">cyber.alert.search</field>
            <field name="model">cyber.alert</field>
            <field name="arch" type="xml">
                <search string="Search Alerts">
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="device_id"/>
                    <separator/>
                    <filter string="Critical" name="critical" domain="[('severity','=','critical')]"/>
                    <filter string="High" name="high" domain="[('severity','=','high')]"/>
                    <filter string="Open" name="open" domain="[('state', 'not in', ['resolved','false_positive'])]"/>
                    <filter string="SLA Breached" name="sla_breached" domain="[('sla_breached','=',True)]"/>
                    <filter string="My Alerts" name="my_alerts" domain="[('assigned_to_id','=',uid)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Severity" name="group_severity" context="{'group_by': 'severity'}"/>
                        <filter string="Device" name="group_device" context="{'group_by': 'device_id'}"/>
                        <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Type" name="group_type" context="{'group_by': 'alert_type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_cyber_alerts" model="ir.actions.act_window">
            <field name="name">All Alerts</field>
            <field name="res_model">cyber.alert</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_cyber_alert_search"/>
        </record>

        <record id="action_cyber_alerts_open" model="ir.actions.act_window">
            <field name="name">Open Alerts</field>
            <field name="res_model">cyber.alert</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', 'not in', ['resolved', 'false_positive'])]</field>
            <field name="context">{'search_default_open': 1}</field>
        </record>

        <record id="action_cyber_alerts_critical" model="ir.actions.act_window">
            <field name="name">Critical Alerts</field>
            <field name="res_model">cyber.alert</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('severity', '=', 'critical'), ('state', 'not in', ['resolved', 'false_positive'])]</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             CYBER.VULNERABILITY — VIEWS
        ══════════════════════════════════════════════════════════════════════ -->
        <record id="view_cyber_vuln_list" model="ir.ui.view">
            <field name="name">cyber.vulnerability.list</field>
            <field name="model">cyber.vulnerability</field>
            <field name="arch" type="xml">
                <list string="Vulnerabilities"
                      decoration-danger="severity == 'critical'"
                      decoration-warning="severity == 'high'"
                      decoration-muted="state in ['patched', 'false_positive']">
                    <field name="cve_id" string="CVE ID"/>
                    <field name="name" string="Vulnerability"/>
                    <field name="device_id" string="Device"/>
                    <field name="cvss_score" string="CVSS"
                           decoration-danger="cvss_score &gt;= 9"
                           decoration-warning="cvss_score &gt;= 7"/>
                    <field name="severity" string="Severity"/>
                    <field name="affected_component" string="Component"/>
                    <field name="state" string="State"/>
                    <field name="detected_date" string="Detected"/>
                    <field name="patched_date" string="Patched" optional="show"/>
                </list>
            </field>
        </record>

        <record id="view_cyber_vuln_form" model="ir.ui.view">
            <field name="name">cyber.vulnerability.form</field>
            <field name="model">cyber.vulnerability</field>
            <field name="arch" type="xml">
                <form string="Vulnerability">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="open,in_progress,patched"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                            <h3 style="color:#64748b;">
                                <field name="cve_id" placeholder="CVE-YYYY-XXXXX"/>
                            </h3>
                        </div>
                        <group>
                            <group string="Classification">
                                <field name="device_id"/>
                                <field name="cvss_score"/>
                                <field name="severity" readonly="1"/>
                                <field name="cvss_vector"/>
                            </group>
                            <group string="Affected Component">
                                <field name="affected_component"/>
                                <field name="affected_version"/>
                                <field name="fixed_version"/>
                                <field name="nvd_url" widget="url" readonly="1"/>
                            </group>
                        </group>
                        <group string="Timeline">
                            <field name="detected_date"/>
                            <field name="patched_date"/>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description" nolabel="1"/>
                            </page>
                            <page string="Remediation Steps">
                                <field name="remediation" nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_cyber_vulnerabilities" model="ir.actions.act_window">
            <field name="name">Vulnerabilities</field>
            <field name="res_model">cyber.vulnerability</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_cyber_vulnerabilities_open" model="ir.actions.act_window">
            <field name="name">Open Vulnerabilities</field>
            <field name="res_model">cyber.vulnerability</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'open')]</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             CYBER.INCIDENT — VIEWS
        ══════════════════════════════════════════════════════════════════════ -->
        <record id="view_cyber_incident_list" model="ir.ui.view">
            <field name="name">cyber.incident.list</field>
            <field name="model">cyber.incident</field>
            <field name="arch" type="xml">
                <list string="Incidents"
                      decoration-danger="severity == 'critical'"
                      decoration-warning="severity == 'high'"
                      decoration-muted="state == 'closed'">
                    <field name="reference" string="Ref"/>
                    <field name="name" string="Incident"/>
                    <field name="device_id" string="Primary Device"/>
                    <field name="severity" string="Severity"/>
                    <field name="state" string="State"/>
                    <field name="source" string="Source"/>
                    <field name="assigned_to_id" string="Lead Analyst"/>
                    <field name="rgpd_notification_required" string="RGPD" widget="boolean"/>
                    <field name="alert_count" string="Alerts"/>
                    <field name="detected_date" string="Detected"/>
                    <field name="closed_date" string="Closed" optional="show"/>
                </list>
            </field>
        </record>

        <record id="view_cyber_incident_form" model="ir.ui.view">
            <field name="name">cyber.incident.form</field>
            <field name="model">cyber.incident</field>
            <field name="arch" type="xml">
                <form string="Security Incident">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="detected,reported,acknowledged,analyzing,containing,recovering,closed"/>
                        <button name="action_close" type="object"
                                string="Close Incident" class="btn-success"
                                attrs="{'invisible': [('state', '=', 'closed')]}"/>
                    </header>
                    <sheet>
                        <!-- RGPD warning -->
                        <div class="alert alert-danger"
                             attrs="{'invisible': [('rgpd_notification_required', '=', False)]}">
                            <strong>⚠️ RGPD NOTIFICATION REQUIRED</strong> —
                            This incident may involve personal data. Notify AEPD within 72 hours.
                            <field name="rgpd_notification_sent" string="Notification Sent"/> ·
                            <field name="rgpd_notification_date" string="Date Sent"/>
                        </div>

                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                            <h3 style="color:#64748b;"><field name="reference" readonly="1"/></h3>
                        </div>

                        <group>
                            <group string="Classification">
                                <field name="severity"/>
                                <field name="source"/>
                                <field name="device_id"/>
                                <field name="assigned_to_id"/>
                            </group>
                            <group string="Timeline">
                                <field name="detected_date"/>
                                <field name="closed_date" readonly="1"/>
                                <field name="rgpd_notification_required"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Description &amp; Impact">
                                <group string="Incident Description">
                                    <field name="description" nolabel="1"/>
                                </group>
                                <group string="Business Impact">
                                    <field name="impact" nolabel="1"/>
                                </group>
                                <group string="Event Timeline">
                                    <field name="timeline" nolabel="1"/>
                                </group>
                            </page>
                            <page string="Response Actions">
                                <group string="Containment Actions">
                                    <field name="containment_actions" nolabel="1"/>
                                </group>
                                <group string="Eradication Actions">
                                    <field name="eradication_actions" nolabel="1"/>
                                </group>
                                <group string="Recovery Actions">
                                    <field name="recovery_actions" nolabel="1"/>
                                </group>
                            </page>
                            <page string="Lessons Learned">
                                <field name="lessons_learned" nolabel="1"/>
                            </page>
                            <page string="Related Alerts">
                                <field name="alert_ids" readonly="1">
                                    <list>
                                        <field name="reference"/>
                                        <field name="name"/>
                                        <field name="severity"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_cyber_incidents" model="ir.actions.act_window">
            <field name="name">Incidents</field>
            <field name="res_model">cyber.incident</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_cyber_incidents_open" model="ir.actions.act_window">
            <field name="name">Active Incidents</field>
            <field name="res_model">cyber.incident</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '!=', 'closed')]</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             CYBER.REPORT — VIEWS
        ══════════════════════════════════════════════════════════════════════ -->
        <record id="view_cyber_report_list" model="ir.ui.view">
            <field name="name">cyber.report.list</field>
            <field name="model">cyber.report</field>
            <field name="arch" type="xml">
                <list string="Audit Reports">
                    <field name="reference"/>
                    <field name="name"/>
                    <field name="report_type"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="state" decoration-success="state == 'approved'"
                           decoration-warning="state == 'generated'"/>
                    <field name="generated_by_id"/>
                    <field name="total_alerts"/>
                    <field name="critical_alerts"/>
                </list>
            </field>
        </record>

        <record id="view_cyber_report_form" model="ir.ui.view">
            <field name="name">cyber.report.form</field>
            <field name="model">cyber.report</field>
            <field name="arch" type="xml">
                <form string="Audit Report">
                    <header>
                        <button name="action_generate" type="object"
                                string="Generate Report" class="btn-primary"
                                attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                        <button name="action_approve" type="object"
                                string="Approve" class="btn-success"
                                attrs="{'invisible': [('state', '!=', 'generated')]}"
                                groups="cyber_shield.group_cyber_admin"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,generated,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                            <h3 style="color:#64748b;"><field name="reference" readonly="1"/></h3>
                        </div>
                        <group>
                            <group string="Report Details">
                                <field name="report_type"/>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="generated_by_id" readonly="1"/>
                            </group>
                            <group string="Statistics" readonly="1">
                                <field name="total_logs"/>
                                <field name="total_alerts"/>
                                <field name="critical_alerts"/>
                                <field name="total_incidents"/>
                                <field name="total_vulnerabilities"/>
                            </group>
                        </group>
                        <group string="Executive Summary">
                            <field name="summary" nolabel="1"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_cyber_reports" model="ir.actions.act_window">
            <field name="name">Audit Reports</field>
            <field name="res_model">cyber.report</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
