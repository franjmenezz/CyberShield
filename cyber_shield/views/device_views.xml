<odoo>
    <data>

        <!-- LIST VIEW -->
        <record id="view_cyber_device_list" model="ir.ui.view">
            <field name="name">cyber.device.list</field>
            <field name="model">cyber.device</field>
            <field name="arch" type="xml">
                <list string="Devices"
                      decoration-danger="status == 'critical'"
                      decoration-warning="status == 'warning'"
                      decoration-muted="status == 'offline'">
                    <field name="display_name" string="Device"/>
                    <field name="device_type" string="Type"/>
                    <field name="department" string="Department"/>
                    <field name="ip_address" string="IP"/>
                    <field name="status" string="Status"
                           decoration-danger="status == 'critical'"
                           decoration-warning="status == 'warning'"
                           decoration-success="status == 'active'"/>
                    <field name="agent_status" string="Agent"
                           decoration-success="agent_status == 'connected'"
                           decoration-danger="agent_status == 'disconnected'"/>
                    <field name="risk_score" string="Risk"/>
                    <field name="log_count" string="Events"/>
                    <field name="alert_count" string="Alerts"/>
                    <field name="last_seen" string="Last Seen"/>
                    <field name="criticality" string="Criticality"/>
                </list>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="view_cyber_device_form" model="ir.ui.view">
            <field name="name">cyber.device.form</field>
            <field name="model">cyber.device</field>
            <field name="arch" type="xml">
                <form string="Device">
                    <header>
                        <field name="status" widget="statusbar"
                               statusbar_visible="active,warning,critical,offline"/>
                        <button name="action_regenerate_token" type="object"
                                string="🔑 Regenerate Token"
                                class="btn-secondary"
                                groups="cyber_shield.group_cyber_admin"/>
                        <button name="action_view_logs" type="object"
                                string="📋 View Activity"
                                class="btn-primary"/>
                        <button name="action_view_alerts" type="object"
                                string="🚨 View Alerts"
                                class="btn-warning"/>
                    </header>
                    <sheet>
                        <!-- Risk banner -->
                        <div class="alert alert-danger" role="alert"
                             invisible="risk_score &lt; 70">
                            <strong>⚠️ HIGH RISK DEVICE</strong> —
                            Risk Score: <field name="risk_score" readonly="1"/>
                            | <field name="critical_alert_count" readonly="1"/> critical alerts open
                        </div>

                        <div class="oe_title">
                            <h1><field name="name" placeholder="Device Name (e.g. Diseño EQ1)"/></h1>
                            <h3 style="color:#64748b;">
                                <field name="device_uid" readonly="1"/>
                            </h3>
                        </div>

                        <!-- Stats row -->
                        <div class="row mb-3">
                            <div class="col-2 text-center p-2" style="background:#f8fafc;border-radius:8px;margin:4px;">
                                <div style="font-size:24px;font-weight:700;color:#4f46e5;">
                                    <field name="log_count" readonly="1"/>
                                </div>
                                <div style="font-size:11px;color:#64748b;">Events</div>
                            </div>
                            <div class="col-2 text-center p-2" style="background:#fef2f2;border-radius:8px;margin:4px;">
                                <div style="font-size:24px;font-weight:700;color:#dc2626;">
                                    <field name="critical_alert_count" readonly="1"/>
                                </div>
                                <div style="font-size:11px;color:#64748b;">Critical</div>
                            </div>
                            <div class="col-2 text-center p-2" style="background:#fffbeb;border-radius:8px;margin:4px;">
                                <div style="font-size:24px;font-weight:700;color:#d97706;">
                                    <field name="alert_count" readonly="1"/>
                                </div>
                                <div style="font-size:11px;color:#64748b;">Alerts</div>
                            </div>
                            <div class="col-2 text-center p-2" style="background:#eef2ff;border-radius:8px;margin:4px;">
                                <div style="font-size:24px;font-weight:700;color:#4f46e5;">
                                    <field name="risk_score" readonly="1"/>
                                </div>
                                <div style="font-size:11px;color:#64748b;">Risk Score</div>
                            </div>
                        </div>

                        <group>
                            <group string="Identity">
                                <field name="device_type"/>
                                <field name="department"/>
                                <field name="criticality"/>
                                <field name="location"/>
                                <field name="assigned_user_id"/>
                                <field name="responsible_id"/>
                            </group>
                            <group string="Agent Status">
                                <field name="agent_status"
                                       decoration-success="agent_status == 'connected'"
                                       decoration-danger="agent_status == 'disconnected'"/>
                                <field name="last_seen" readonly="1"/>
                                <field name="agent_version" readonly="1"/>
                                <field name="wazuh_agent_id" readonly="1"/>
                                <field name="agent_token" readonly="1"
                                       groups="cyber_shield.group_cyber_admin"/>
                            </group>
                        </group>

                        <group>
                            <group string="Technical">
                                <field name="os_type"/>
                                <field name="os_version"/>
                                <field name="ip_address"/>
                                <field name="mac_address"/>
                                <field name="hostname"/>
                                <field name="serial_number"/>
                                <field name="manufacturer"/>
                                <field name="model"/>
                            </group>
                        </group>

                        <notebook>
                            <!-- ACTIVITY LOG TAB — el más importante -->
                            <page string="📋 Activity Log" name="activity">
                                <group>
                                    <field name="log_ids" readonly="1" nolabel="1"
                                           domain="[('device_id', '=', id)]"
                                           context="{'default_device_id': id}">
                                        <list decoration-danger="severity == 'critical'"
                                              decoration-warning="severity == 'high'"
                                              decoration-muted="severity == 'info'"
                                              default_order="timestamp desc"
                                              limit="100">
                                            <field name="timestamp" string="When"/>
                                            <field name="event_type" string="Event"/>
                                            <field name="severity" string="Severity"
                                                   decoration-danger="severity == 'critical'"
                                                   decoration-warning="severity == 'high'"
                                                   decoration-success="severity == 'low'"
                                                   decoration-muted="severity == 'info'"/>
                                            <field name="description" string="Description"/>
                                            <field name="user_name" string="User"/>
                                            <field name="source_ip" string="Source IP"/>
                                            <field name="process_name" string="Process"/>
                                            <field name="file_path" string="File" optional="hide"/>
                                            <field name="destination_ip" string="Dest. IP" optional="hide"/>
                                            <field name="mitre_tactic" string="MITRE" optional="hide"/>
                                        </list>
                                    </field>
                                </group>
                            </page>

                            <!-- ALERTS TAB -->
                            <page string="🚨 Alerts" name="alerts">
                                <field name="alert_ids" readonly="1">
                                    <list decoration-danger="severity == 'critical'"
                                          decoration-warning="severity == 'high'"
                                          decoration-muted="state in ['resolved','false_positive']"
                                          default_order="create_date desc">
                                        <field name="reference"/>
                                        <field name="name"/>
                                        <field name="severity"
                                               decoration-danger="severity == 'critical'"
                                               decoration-warning="severity == 'high'"/>
                                        <field name="alert_type"/>
                                        <field name="state"/>
                                        <field name="create_date"/>
                                        <field name="sla_deadline"/>
                                        <field name="sla_breached" widget="boolean"/>
                                    </list>
                                </field>
                            </page>

                            <!-- VULNERABILITIES TAB -->
                            <page string="🔓 Vulnerabilities" name="vulns">
                                <field name="vulnerability_ids">
                                    <list decoration-danger="severity == 'critical'"
                                          decoration-warning="severity == 'high'">
                                        <field name="cve_id"/>
                                        <field name="name"/>
                                        <field name="cvss_score"/>
                                        <field name="severity"/>
                                        <field name="state"/>
                                        <field name="detected_date"/>
                                    </list>
                                </field>
                            </page>

                            <!-- INCIDENTS TAB -->
                            <page string="🔥 Incidents" name="incidents">
                                <field name="incident_ids" readonly="1">
                                    <list decoration-danger="severity == 'critical'"
                                          decoration-muted="state == 'closed'">
                                        <field name="reference"/>
                                        <field name="name"/>
                                        <field name="severity"/>
                                        <field name="state"/>
                                        <field name="detected_date"/>
                                    </list>
                                </field>
                            </page>

                            <!-- NOTES TAB -->
                            <page string="Notes" name="notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- SEARCH VIEW -->
        <record id="view_cyber_device_search" model="ir.ui.view">
            <field name="name">cyber.device.search</field>
            <field name="model">cyber.device</field>
            <field name="arch" type="xml">
                <search string="Search Devices">
                    <field name="name" string="Device Name"/>
                    <field name="ip_address" string="IP Address"/>
                    <field name="hostname" string="Hostname"/>
                    <separator/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Agent Connected" name="connected"
                            domain="[('agent_status', '=', 'connected')]"/>
                    <filter string="Agent Disconnected" name="disconnected"
                            domain="[('agent_status', '=', 'disconnected')]"/>
                    <separator/>
                    <filter string="Workstations" name="workstations"
                            domain="[('device_type', 'in', ['workstation', 'laptop'])]"/>
                    <filter string="Servers" name="servers"
                            domain="[('device_type', 'in', ['server', 'virtual'])]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Type" name="group_type"
                                context="{'group_by': 'device_type'}"/>
                        <filter string="Department" name="group_dept"
                                context="{'group_by': 'department'}"/>
                        <filter string="Status" name="group_status"
                                context="{'group_by': 'status'}"/>
                        <filter string="OS" name="group_os"
                                context="{'group_by': 'os_type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ACTIONS -->
        <record id="action_cyber_devices" model="ir.actions.act_window">
            <field name="name">All Devices</field>
            <field name="res_model">cyber.device</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_cyber_device_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No devices registered yet.</p>
                <p>Add your first device and install the monitoring agent to start tracking activity.</p>
            </field>
        </record>

        <record id="action_cyber_workstations" model="ir.actions.act_window">
            <field name="name">Workstations</field>
            <field name="res_model">cyber.device</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('device_type', 'in', ['workstation', 'laptop'])]</field>
            <field name="search_view_id" ref="view_cyber_device_search"/>
        </record>

        <record id="action_cyber_servers" model="ir.actions.act_window">
            <field name="name">Servers</field>
            <field name="res_model">cyber.device</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('device_type', 'in', ['server', 'virtual'])]</field>
            <field name="search_view_id" ref="view_cyber_device_search"/>
        </record>

    </data>
</odoo>
