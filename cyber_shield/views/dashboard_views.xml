<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════════════════
             DASHBOARD ACTION — Uses ODOO's native kanban as dashboard
        ══════════════════════════════════════════════════════════════════════ -->
        <record id="view_cyber_dashboard" model="ir.ui.view">
            <field name="name">cyber.dashboard</field>
            <field name="model">cyber.alert</field>
            <field name="arch" type="xml">
                <form string="CyberShield Dashboard">
                    <sheet>

                        <!-- Header -->
                        <div style="background:linear-gradient(135deg,#4f46e5,#7c3aed);
                                    color:white;padding:24px;border-radius:12px;margin-bottom:24px;">
                            <h1 style="margin:0;font-size:28px;">🛡️ CyberShield</h1>
                            <p style="margin:4px 0 0;opacity:0.8;">
                                Enterprise Security Dashboard — Real-time Overview
                            </p>
                        </div>

                        <!-- KPI Cards Row -->
                        <div class="row mb-4">
                            <!-- Critical Alerts -->
                            <div class="col-md-3">
                                <div style="background:#fef2f2;border:1px solid #fecaca;
                                            border-left:4px solid #dc2626;border-radius:8px;padding:16px;">
                                    <div style="font-size:32px;font-weight:700;color:#dc2626;">
                                        <field name="id" invisible="1"/>
                                    </div>
                                    <div style="font-size:14px;color:#64748b;font-weight:600;">
                                        🚨 Critical Alerts
                                    </div>
                                    <div style="font-size:12px;color:#94a3b8;margin-top:4px;">
                                        Requires immediate action
                                    </div>
                                </div>
                            </div>

                            <!-- Open Incidents -->
                            <div class="col-md-3">
                                <div style="background:#fffbeb;border:1px solid #fde68a;
                                            border-left:4px solid #d97706;border-radius:8px;padding:16px;">
                                    <div style="font-size:32px;font-weight:700;color:#d97706;">
                                        --
                                    </div>
                                    <div style="font-size:14px;color:#64748b;font-weight:600;">
                                        🔥 Active Incidents
                                    </div>
                                    <div style="font-size:12px;color:#94a3b8;margin-top:4px;">
                                        Under investigation
                                    </div>
                                </div>
                            </div>

                            <!-- Online Devices -->
                            <div class="col-md-3">
                                <div style="background:#f0fdf4;border:1px solid #bbf7d0;
                                            border-left:4px solid #16a34a;border-radius:8px;padding:16px;">
                                    <div style="font-size:32px;font-weight:700;color:#16a34a;">
                                        --
                                    </div>
                                    <div style="font-size:14px;color:#64748b;font-weight:600;">
                                        💻 Online Devices
                                    </div>
                                    <div style="font-size:12px;color:#94a3b8;margin-top:4px;">
                                        Agents connected
                                    </div>
                                </div>
                            </div>

                            <!-- Open Vulnerabilities -->
                            <div class="col-md-3">
                                <div style="background:#eef2ff;border:1px solid #c7d2fe;
                                            border-left:4px solid #4f46e5;border-radius:8px;padding:16px;">
                                    <div style="font-size:32px;font-weight:700;color:#4f46e5;">
                                        --
                                    </div>
                                    <div style="font-size:14px;color:#64748b;font-weight:600;">
                                        🔓 Open CVEs
                                    </div>
                                    <div style="font-size:12px;color:#94a3b8;margin-top:4px;">
                                        Unpatched vulnerabilities
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Quick Access Buttons -->
                        <div style="background:#f8fafc;border:1px solid #e2e8f0;
                                    border-radius:8px;padding:16px;margin-bottom:16px;">
                            <h3 style="margin:0 0 12px;color:#0f172a;">Quick Actions</h3>
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="action" name="%(action_cyber_alerts_critical)d"
                                        class="btn btn-danger btn-sm">
                                    🚨 Critical Alerts
                                </button>
                                <button type="action" name="%(action_cyber_incidents_open)d"
                                        class="btn btn-warning btn-sm">
                                    🔥 Active Incidents
                                </button>
                                <button type="action" name="%(action_cyber_devices)d"
                                        class="btn btn-primary btn-sm">
                                    💻 All Devices
                                </button>
                                <button type="action" name="%(action_cyber_vulnerabilities_open)d"
                                        class="btn btn-secondary btn-sm">
                                    🔓 Open CVEs
                                </button>
                                <button type="action" name="%(action_cyber_logs_critical)d"
                                        class="btn btn-outline-danger btn-sm">
                                    📋 Critical Logs
                                </button>
                            </div>
                        </div>

                        <!-- Recent Critical Alerts Table -->
                        <div style="border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;">
                            <div style="background:#0f172a;color:white;padding:12px 16px;">
                                <strong>🚨 Recent Unresolved Alerts</strong>
                            </div>
                            <field name="id" invisible="1"/>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_cyber_dashboard" model="ir.actions.act_window">
            <field name="name">CyberShield Dashboard</field>
            <field name="res_model">cyber.alert</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', 'not in', ['resolved', 'false_positive'])]</field>
            <field name="context">{'search_default_critical': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    🛡️ No open alerts — System secure!
                </p>
                <p>CyberShield is monitoring all registered devices.</p>
            </field>
        </record>

    </data>
</odoo>
